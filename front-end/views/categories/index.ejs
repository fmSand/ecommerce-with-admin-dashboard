<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title: 'Categories' }) %>
<body>
<div class="shell d-flex vh-100 overflow-hidden">
  <%- include('../partials/sidebar', { active: 'categories' }) %>
  <main class="main d-flex flex-column overflow-hidden flex-grow-1">
    <%- include('../partials/topbar', { pageTitle: 'Categories', breadcrumbParent: 'Catalogue' }) %>
    <div class="content flex-grow-1 overflow-y-auto">
      <%- include('../partials/flash') %>
      <header class="d-flex align-items-start justify-content-between mb-4">
        <div>
          <h1 class="page-title h4 mb-1 fw-bold">Categories</h1>
          <p class="page-sub mb-0"><%= categories.length %> categor<%= categories.length !== 1 ? 'ies' : 'y' %> total</p>
        </div>
        <button type="button" class="btn btn-primary" id="category-add-btn">
          <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>
          Add Category
        </button>
      </header>
      <div id="alert-container" class="mb-3" role="status" aria-live="polite" aria-atomic="true"></div>
      <div class="panel">
        <div class="table-toolbar d-flex align-items-center justify-content-between">
          <span class="table-toolbar-title">All Categories</span>
          <span class="table-toolbar-meta"><%= categories.length %> record<%= categories.length !== 1 ? 's' : '' %></span>
        </div>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th scope="col" style="width: 50px;">ID</th>
                <th scope="col">Name</th>
                <th scope="col" class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <tr id="category-add-row" class="d-none">
                <td></td>
                <td>
                  <label for="category-new-name" class="visually-hidden">Category name</label>
                  <input
                    type="text"
                    id="category-new-name"
                    class="form-control form-control-sm"
                    placeholder="Category name"
                    maxlength="100"
                  >
                </td>
                <td class="text-end">
                  <div class="d-flex gap-2 justify-content-end">
                    <button class="btn-action restore" id="category-save-new-btn" type="button">
                      <i class="bi bi-check-lg me-1" aria-hidden="true"></i>Save
                    </button>
                    <button class="btn-action danger" id="category-cancel-new-btn" type="button">
                      Cancel
                    </button>
                  </div>
                </td>
              </tr>
              <% if (categories.length === 0) { %>
                <tr>
                  <td colspan="3" class="text-center py-4" style="color: var(--text-3); font-size: 0.82rem;">
                    No categories yet. Click 'Add Category' to create one.
                  </td>
                </tr>
              <% } %>
              <% categories.forEach(category => { %>
                <tr data-id="<%= category.id %>">
                  <td class="text-muted"><%= category.id %></td>
                  <td>
                    <span class="category-name fw-medium">
                      <%= category.name %>
                    </span>
                    <div class="category-edit-form d-none">
                      <input
                        type="text"
                        class="form-control form-control-sm"
                        value="<%= category.name %>"
                        maxlength="100"
                        style="max-width: 280px;"
                        aria-label="Edit category name for <%= category.name %>"
                      >
                    </div>
                  </td>
                  <td class="text-end">
                    <div class="d-flex gap-2 justify-content-end category-actions">
                      <button class="btn-action category-edit-btn" type="button">
                        <i class="bi bi-pencil me-1" aria-hidden="true"></i>Edit
                      </button>
                      <button class="btn-action danger category-delete-btn" type="button">
                        <i class="bi bi-trash me-1" aria-hidden="true"></i>Delete
                      </button>
                    </div>
                    <div class="category-edit-actions d-none d-flex gap-2 justify-content-end">
                      <button class="btn-action restore save-btn" type="button">
                        <i class="bi bi-check-lg me-1" aria-hidden="true"></i>Save
                      </button>
                      <button class="btn-action cancel-btn" type="button">
                        Cancel
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>
<script src="/js/crud.js"></script>
<script src="/js/categories.js"></script>
<%- include('../partials/scripts') %>
</body>
</html>
