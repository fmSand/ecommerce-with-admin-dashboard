<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Sign In' }) %>
<body>
<div class="d-flex min-vh-100 overflow-hidden">
  <div class="login-panel d-none d-md-flex flex-column justify-content-between overflow-hidden position-relative">
    <div class="login-panel-inner position-relative z-1">
      <div class="d-flex align-items-center gap-2 mb-5">
        <div class="logo-mark d-flex align-items-center justify-content-center flex-shrink-0">
          <svg viewBox="0 0 16 16" aria-hidden="true">
            <path d="M2 2h12l1 3H1L2 2zM1 6h14v8H1V6zm3 2v4h8V8H4z"/>
          </svg>
        </div>
        <div class="logo-text">EP<span>Admin</span></div>
      </div>
      <h1 class="login-panel-heading mb-4 fw-bold">
        Manage your
        <em class="d-block">e-commerce</em>
        platform.
      </h1>
      <ul class="feature-list list-unstyled">
        <li class="d-flex align-items-center gap-2 mb-2"><span class="feature-dot flex-shrink-0"></span>Product &amp; inventory management</li>
        <li class="d-flex align-items-center gap-2 mb-2"><span class="feature-dot flex-shrink-0"></span>Order processing &amp; status tracking</li>
        <li class="d-flex align-items-center gap-2 mb-2"><span class="feature-dot flex-shrink-0"></span>User roles &amp; membership tiers</li>
        <li class="d-flex align-items-center gap-2 mb-2"><span class="feature-dot flex-shrink-0"></span>Brand &amp; category management</li>
      </ul>
    </div>
    <div class="login-panel-footer position-relative d-flex align-items-center gap-2 z-1 pt-3">
      <span class="status-dot flex-shrink-0" aria-hidden="true"></span>
      <span class="status-text">API on port 3000 · Admin on port 3001</span>
    </div>
  </div>

  <div class="login-form-area flex-grow-1 d-flex align-items-center justify-content-center">
    <div class="login-form-card w-100">
      <div class="login-eyebrow text-uppercase mb-2">Admin portal</div>
      <h2 class="login-title">Welcome back</h2>
      <p class="login-hint mb-4">Sign in with your admin credentials to continue.</p>
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-theme-danger mb-4" role="alert">
          <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
          <%= message %>
        </div>
      <% } %>
      <form method="POST" action="/auth/login" novalidate>
        <div class="mb-3">
          <label for="identifier" class="form-label fw-medium" style="font-size:0.78rem;">
            Username or Email
          </label>
          <input
            type="text"
            id="identifier"
            name="identifier"
            class="form-control"
            placeholder="Enter your username or email"
            autocomplete="username"
            required
            autofocus
          >
        </div>
        <div class="mb-3">
          <label for="password" class="form-label fw-medium" style="font-size:0.78rem;">
            Password
          </label>
          <div class="position-relative">
            <input
              type="password"
              id="password"
              name="password"
              class="form-control"
              placeholder="Enter password"
              autocomplete="current-password"
              required
            >
            <button
              type="button"
              class="pwd-toggle"
              aria-label="Toggle password visibility"
              onclick="togglePassword()"
            >
              <i class="bi bi-eye" id="pwd-icon" aria-hidden="true"></i>
            </button>
          </div>
        </div>
        <button type="submit" class="btn btn-primary w-100 mt-1">
          Sign in to Admin Panel
        </button>
      </form>
      <div class="login-footer p-3"></div>
    </div>
  </div>
</div>
<%- include('partials/scripts') %>
<script>
  function togglePassword() {
    const input = document.getElementById('password');
    const icon  = document.getElementById('pwd-icon');
    const show  = input.type === 'password';
    input.type  = show ? 'text' : 'password';
    icon.className = show ? 'bi bi-eye' : 'bi bi-eye-slash';
  }
</script>
</body>
</html>
