<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title: profile.username }) %>
<body>
<div class="shell d-flex vh-100 overflow-hidden">
  <%- include('../partials/sidebar', { active: 'users' }) %>
  <main class="main d-flex flex-column overflow-hidden flex-grow-1">
    <%- include('../partials/topbar', {
      pageTitle: `${profile.firstName} ${profile.lastName}`,
      breadcrumbParent: 'Users'
    }) %>
    <div class="content flex-grow-1 overflow-y-auto">
      <%- include('../partials/flash') %>
      <a href="/users" class="btn btn-outline-secondary btn-sm mb-4">
        <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Back to Users
      </a>

      <div class="row g-4">
        <%# Edit form %>
        <div class="col-lg-8">
          <div class="panel">
            <div class="table-toolbar d-flex align-items-center justify-content-between">
              <span class="table-toolbar-title">Profile</span>
            </div>
            <div class="p-4">
              <% if (typeof formError !== 'undefined' && formError) { %>
                <div class="alert alert-theme-danger mb-4" role="alert">
                  <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
                  <%= formError %>
                </div>
              <% } %>
              <form method="POST" action="/users/<%= profile.id %>/edit" novalidate>
                <div class="row g-3 mb-3">
                  <div class="col-md-6">
                    <label for="firstName" class="form-label">First Name</label>
                    <input
                      type="text"
                      id="firstName"
                      name="firstName"
                      class="form-control <%= fieldErrors.firstName ? 'is-invalid' : '' %>"
                      value="<%= formData?.firstName ?? profile.firstName ?? '' %>"
                      required
                    >
                    <% if (fieldErrors.firstName) { %>
                      <div class="invalid-feedback"><%= fieldErrors.firstName %></div>
                    <% } %>
                  </div>
                  <div class="col-md-6">
                    <label for="lastName" class="form-label">Last Name</label>
                    <input
                      type="text"
                      id="lastName"
                      name="lastName"
                      class="form-control <%= fieldErrors.lastName ? 'is-invalid' : '' %>"
                      value="<%= formData?.lastName ?? profile.lastName ?? '' %>"
                      required
                    >
                    <% if (fieldErrors.lastName) { %>
                      <div class="invalid-feedback"><%= fieldErrors.lastName %></div>
                    <% } %>
                  </div>
                </div>
                <div class="row g-3 mb-3">
                  <div class="col-md-6">
                    <label for="username" class="form-label">Username</label>
                    <div class="input-group">
                      <span class="input-group-text">@</span>
                      <input
                        type="text"
                        id="username"
                        name="username"
                        class="form-control <%= fieldErrors.username ? 'is-invalid' : '' %>"
                        value="<%= formData?.username ?? profile.username ?? '' %>"
                        required
                      >
                      <% if (fieldErrors.username) { %>
                        <div class="invalid-feedback"><%= fieldErrors.username %></div>
                      <% } %>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <label for="email" class="form-label">Email</label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      class="form-control <%= fieldErrors.email ? 'is-invalid' : '' %>"
                      value="<%= formData?.email ?? profile.email ?? '' %>"
                      required
                    >
                    <% if (fieldErrors.email) { %>
                      <div class="invalid-feedback"><%= fieldErrors.email %></div>
                    <% } %>
                  </div>
                </div>
                <div class="mb-3">
                  <label for="address" class="form-label">Address</label>
                  <input
                    type="text"
                    id="address"
                    name="address"
                    class="form-control <%= fieldErrors.address ? 'is-invalid' : '' %>"
                    value="<%= formData?.address ?? profile.address ?? '' %>"
                  >
                  <% if (fieldErrors.address) { %>
                    <div class="invalid-feedback"><%= fieldErrors.address %></div>
                  <% } %>
                </div>
                <div class="row g-3 mb-4">
                  <div class="col-md-6">
                    <label for="city" class="form-label">City</label>
                    <input
                      type="text"
                      id="city"
                      name="city"
                      class="form-control <%= fieldErrors.city ? 'is-invalid' : '' %>"
                      value="<%= formData?.city ?? profile.city ?? '' %>"
                    >
                    <% if (fieldErrors.city) { %>
                      <div class="invalid-feedback"><%= fieldErrors.city %></div>
                    <% } %>
                  </div>
                  <div class="col-md-6">
                    <label for="phone" class="form-label">Phone</label>
                    <input
                      type="text"
                      id="phone"
                      name="phone"
                      class="form-control <%= fieldErrors.phone ? 'is-invalid' : '' %>"
                      value="<%= formData?.phone ?? profile.phone ?? '' %>"
                    >
                    <% if (fieldErrors.phone) { %>
                      <div class="invalid-feedback"><%= fieldErrors.phone %></div>
                    <% } %>
                  </div>
                </div>
                <div class="d-flex gap-2">
                  <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1" aria-hidden="true"></i>Save Changes
                  </button>
                  <a href="/users/<%= profile.id %>" class="btn btn-outline-secondary">Discard changes</a>
                </div>
              </form>
            </div>
          </div>
        </div>

        <div class="col-lg-4">
          <%# User info %>
          <div class="panel mb-4">
            <div class="table-toolbar d-flex align-items-center justify-content-between">
              <span class="table-toolbar-title">Account Info</span>
            </div>
            <div class="p-3">
              <div class="d-flex align-items-center gap-3 mb-3 pb-3" style="border-bottom: 1px solid var(--border);">
                <div class="avatar-initials avatar-initials--lg d-flex align-items-center justify-content-center fw-bold" aria-hidden="true">
                  <%= (profile.firstName?.[0] || '') + (profile.lastName?.[0] || '') %>
                </div>
                <div>
                  <div class="fw-semibold" style="font-size: 0.88rem; color: var(--text);">
                    <%= profile.firstName %> <%= profile.lastName %>
                  </div>
                  <div style="font-size: 0.72rem; color: var(--text-3);">@<%= profile.username %></div>
                </div>
              </div>
              <dl class="mb-0" style="font-size: 0.78rem;">
                <div class="d-flex justify-content-between py-2" style="border-bottom: 1px solid var(--border);">
                  <dt class="fw-medium" style="color: var(--text-3);">Role</dt>
                  <dd class="mb-0">
                    <% if (profile.role?.name === 'Admin') { %>
                      <span class="badge-stock badge-active"><span class="badge-dot"></span>Admin</span>
                    <% } else { %>
                      <span class="badge-stock badge-deleted">User</span>
                    <% } %>
                  </dd>
                </div>
                <div class="d-flex justify-content-between py-2" style="border-bottom: 1px solid var(--border);">
                  <dt class="fw-medium" style="color: var(--text-3);">Membership</dt>
                  <dd class="mb-0" style="color: var(--text);"><%= profile.membership?.name || 'Bronze' %></dd>
                </div>
                <div class="d-flex justify-content-between py-2" style="border-bottom: 1px solid var(--border);">
                  <dt class="fw-medium" style="color: var(--text-3);">Total Purchased</dt>
                  <dd class="mb-0" style="color: var(--text);"><%= profile.totalPurchasedQuantity || 0 %> items</dd>
                </div>
                <div class="d-flex justify-content-between py-2">
                  <dt class="fw-medium" style="color: var(--text-3);">Member since</dt>
                  <dd class="mb-0" style="color: var(--text);">
                    <%= profile.createdAt ? new Date(profile.createdAt).toLocaleDateString('en-GB') : '—' %>
                  </dd>
                </div>
              </dl>
            </div>
          </div>

          <%# Role change and delete options %>
          <div class="panel mb-4">
            <div class="table-toolbar d-flex align-items-center justify-content-between">
              <span class="table-toolbar-title">Change Role</span>
            </div>
            <div class="p-3">
              <p class="mb-3" style="font-size: 0.75rem; color: var(--text-3);">
                Changing to Admin grants full access to this admin panel.
              </p>
              <form method="POST" action="/users/<%= profile.id %>/role">
                <div class="mb-3">
                  <label for="roleId" class="form-label" style="font-size: 0.78rem;">Role</label>
                  <select id="roleId" name="roleId" class="form-select form-select-sm">
                    <% roles.forEach(r => { %>
                      <option
                        value="<%= r.id %>"
                        <%= r.id === profile.roleId ? 'selected' : '' %>
                      ><%= r.name %></option>
                    <% }) %>
                  </select>
                </div>
                <button type="submit" class="btn btn-primary btn-sm w-100">
                  Update Role
                </button>
              </form>
            </div>
          </div>
          <div class="panel" style="border-color: rgba(229, 62, 62, 0.3);">
            <div class="table-toolbar d-flex align-items-center justify-content-between" style="border-bottom-color: rgba(229, 62, 62, 0.15);">
              <span class="table-toolbar-title" style="color: var(--danger);">
                <i class="bi bi-exclamation-triangle me-1" aria-hidden="true"></i>
                Danger Zone
              </span>
            </div>
            <div class="p-3">
              <p class="mb-3" style="font-size: 0.75rem; color: var(--text-3);">
                Permanently deletes this user. Users with existing orders cannot be deleted.
              </p>
              <form method="POST" action="/users/<%= profile.id %>/delete">
                <button
                  type="submit"
                  class="btn btn-sm w-100"
                  style="background: var(--danger-bg); border: 1px solid rgba(229,62,62,0.3); color: var(--danger); font-size: 0.78rem;"
                  data-name="<%= profile.username %>"
                  onclick="return confirm('Delete user ' + this.dataset.name + '? This cannot be undone.')"
                >
                  <i class="bi bi-trash me-1" aria-hidden="true"></i>Delete User
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/scripts') %>
</body>
</html>
