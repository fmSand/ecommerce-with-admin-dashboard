<% if (typeof flash !== 'undefined' && flash) { %>
  <% const isUrgent = flash.type === 'danger' || flash.type === 'warning'; %>
  <div
    class="alert alert-theme-<%= flash.type %> alert-dismissible mb-4"
    role="<%= isUrgent ? 'alert' : 'status' %>"
    aria-live="<%= isUrgent ? 'assertive' : 'polite' %>"
    aria-atomic="true"
  >
    <% if (flash.type === 'success') { %>
      <i class="bi bi-check-circle-fill me-2" aria-hidden="true"></i>
    <% } else if (flash.type === 'danger') { %>
      <i class="bi bi-exclamation-triangle-fill me-2" aria-hidden="true"></i>
    <% } else if (flash.type === 'warning') { %>
      <i class="bi bi-exclamation-circle-fill me-2" aria-hidden="true"></i>
    <% } %>
    <%= flash.message %>
    <button
      type="button"
      class="btn-close btn-close-sm ms-auto"
      data-bs-dismiss="alert"
      aria-label="Close"
    ></button>
  </div>
<% } %>
