<aside class="sidebar d-flex flex-column overflow-hidden">
  <div class="sb-logo d-flex align-items-center gap-2 flex-shrink-0">
    <a class="logo-mark d-flex align-items-center justify-content-center flex-shrink-0" href="/dashboard" aria-label="Go to dashboard">
      <svg viewBox="0 0 16 16" aria-hidden="true" focusable="false">
        <path d="M2 2h12l1 3H1L2 2zM1 6h14v8H1V6zm3 2v4h8V8H4z"/>
      </svg>
    </a>
    <div class="logo-text">EP<span>Admin</span></div>
  </div>
  <nav class="sb-nav flex-grow-1 overflow-y-auto" aria-label="Main navigation">
    <div class="sb-section mb-3">
      <h2 class="sb-section-label fw-semibold text-uppercase">Overview</h2>
      <ul class="list-unstyled mb-0">
        <li class="sb-item <%= active === 'dashboard' ? 'active' : '' %>">
          <a href="/dashboard">
            <i class="bi bi-grid-fill" aria-hidden="true"></i>
            Dashboard
          </a>
        </li>
      </ul>
    </div>
    <div class="sb-section mb-3">
      <h2 class="sb-section-label fw-semibold text-uppercase">Catalogue</h2>
      <ul class="list-unstyled mb-0">
        <li class="sb-item <%= active === 'products' ? 'active' : '' %>">
          <a href="/products" <%= active === 'products' ? 'aria-current="page"' : '' %>>
            <i class="bi bi-box-seam" aria-hidden="true"></i>
            Products
          </a>
        </li>
        <li class="sb-item <%= active === 'categories' ? 'active' : '' %>">
          <a href="/categories" <%= active === 'categories' ? 'aria-current="page"' : '' %>>
            <i class="bi bi-collection" aria-hidden="true"></i>
            Categories
          </a>
        </li>
        <li class="sb-item <%= active === 'brands' ? 'active' : '' %>">
          <a href="/brands" <%= active === 'brands' ? 'aria-current="page"' : '' %>>
            <i class="bi bi-tag" aria-hidden="true"></i>
            Brands
          </a>
        </li>
      </ul>
    </div>
    <div class="sb-divider"></div>
    <div class="sb-section">
      <h2 class="sb-section-label fw-semibold text-uppercase">Commerce</h2>
      <ul class="list-unstyled mb-0">
        <li class="sb-item <%= active === 'orders' ? 'active' : '' %>">
          <a href="/orders" <%= active === 'orders' ? 'aria-current="page"' : '' %>>
            <i class="bi bi-receipt" aria-hidden="true"></i>
            Orders
          </a>
        </li>
        <li class="sb-item <%= active === 'users' ? 'active' : '' %>">
          <a href="/users" <%= active === 'users' ? 'aria-current="page"' : '' %>>
            <i class="bi bi-people" aria-hidden="true"></i>
            Users
          </a>
        </li>
        <li class="sb-item <%= active === 'memberships' ? 'active' : '' %>">
          <a href="/memberships" <%= active === 'memberships' ? 'aria-current="page"' : '' %>>
            <i class="bi bi-award" aria-hidden="true"></i>
            Memberships
          </a>
        </li>
      </ul>
    </div>
  </nav>
  <div class="sb-footer flex-shrink-0">
    <% if (user) { %>
      <div class="d-flex align-items-center gap-2 mb-3">
        <div class="avatar-initials d-flex align-items-center justify-content-center fw-bold" aria-hidden="true">
          <%= user.name.split(' ').map(w => w[0]).join('').slice(0, 2) %>
        </div>
        <div>
          <div class="sb-user-name fw-medium"><%= user.name %></div>
          <div class="sb-user-email"><%= user.email %></div>
        </div>
      </div>
    <% } %>
    <form method="POST" action="/auth/logout">
      <button type="submit" class="btn-logout w-100 d-flex gap-2">
        <i class="bi bi-box-arrow-left" aria-hidden="true"></i>
        Sign out
      </button>
    </form>
  </div>
</aside>
