<!DOCTYPE html>
<html lang="en">
<%- include('partials/head', { title: 'Error' }) %>
<body class="bg-light d-flex align-items-center min-vh-100">
  <div class="container text-center">
    <h1 class="display-1 text-muted"><%= typeof status !== 'undefined' ? status : '' %></h1>
    <p class="lead"><%= message %></p>
    <a href="/dashboard" class="btn btn-primary mt-3">Back to Dashboard</a>
    <% if (typeof error !== 'undefined' && error && error.stack) { %>
      <pre class="text-start mt-4 p-3 bg-white rounded small"><%= error.stack %></pre>
    <% } %>
  </div>
  <%- include('partials/scripts') %>
</body>
</html>
