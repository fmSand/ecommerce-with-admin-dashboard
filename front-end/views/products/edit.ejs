<!DOCTYPE html>
<html lang="en">
<%- include('../partials/head', { title: `Edit: ${product.name}` }) %>
<body>
<div class="shell d-flex vh-100 overflow-hidden">
  <%- include('../partials/sidebar', { active: 'products' }) %>
  <main class="main d-flex flex-column overflow-hidden flex-grow-1">
    <%- include('../partials/topbar', { pageTitle: 'Edit Product', breadcrumbParent: 'Products' }) %>
    <div class="content flex-grow-1 overflow-y-auto">
      <a href="/products" class="btn btn-outline-secondary btn-sm mb-4">
        <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>Back to Products
      </a>
      <% if (product.isDeleted) { %>
        <div class="alert alert-theme-warning d-flex align-items-center gap-3 mb-4" role="alert">
          <i class="bi bi-exclamation-triangle-fill flex-shrink-0" aria-hidden="true"></i>
          <span>This product is deleted and hidden from customers.</span>
          <form method="POST" action="/products/<%= product.id %>/restore" class="ms-auto flex-shrink-0">
            <button
              type="submit"
              class="btn-action restore"
              onclick="return confirm('Restore this product?')"
            >
              <i class="bi bi-arrow-counterclockwise me-1" aria-hidden="true"></i>Restore
            </button>
          </form>
        </div>
      <% } %>
      <div class="row g-4">
        <div class="col-lg-8">
          <div class="panel">
            <div class="table-toolbar d-flex align-items-center justify-content-between">
              <span class="table-toolbar-title">Edit Product</span>
            </div>
            <div class="p-4">
              <%- include('../partials/form', {
                action: `/products/${product.id}/edit`,
                submitLabel: 'Save Changes',
                brands,
                categories,
                formData,
                fieldErrors,
                formError,
                product
              }) %>
            </div>
          </div>
        </div>

        <div class="col-lg-4">
          <div class="panel mb-4">
            <div class="table-toolbar d-flex align-items-center justify-content-between">
              <span class="table-toolbar-title">Product Info</span>
            </div>
            <div class="p-3">
              <% if (product.imgUrl) { %>
                <div class="text-center mb-3 p-2" style="background: var(--bg); border-radius: 6px;">
                  <img
                    src="<%= product.imgUrl %>"
                    alt="<%= product.name %>"
                    style="max-width: 100%; max-height: 120px; object-fit: contain;"
                    onerror="this.parentElement.style.display='none'"
                  >
                </div>
              <% } %>
              <dl class="mb-0" style="font-size: 0.78rem;">
                <div class="d-flex justify-content-between py-2" style="border-bottom: 1px solid var(--border);">
                  <dt class="fw-medium" style="color: var(--text-3);">ID</dt>
                  <dd class="mb-0" style="color: var(--text);">#<%= product.id %></dd>
                </div>
                <div class="d-flex justify-content-between py-2" style="border-bottom: 1px solid var(--border);">
                  <dt class="fw-medium" style="color: var(--text-3);">Status</dt>
                  <dd class="mb-0">
                    <% if (product.isDeleted) { %>
                      <span class="badge-stock badge-deleted">Deleted</span>
                    <% } else { %>
                      <span class="badge-stock badge-active">
                        <span class="badge-dot"></span>Active
                      </span>
                    <% } %>
                  </dd>
                </div>
                <div class="d-flex justify-content-between py-2" style="border-bottom: 1px solid var(--border);">
                  <dt class="fw-medium" style="color: var(--text-3);">Date Added</dt>
                  <dd class="mb-0" style="color: var(--text);">
                    <%= product.dateAdded
                          ? new Date(product.dateAdded).toLocaleDateString('en-GB')
                          : '—' %>
                  </dd>
                </div>
                <div class="d-flex justify-content-between py-2">
                  <dt class="fw-medium" style="color: var(--text-3);">Last Updated</dt>
                  <dd class="mb-0" style="color: var(--text);">
                    <%= product.updatedAt
                          ? new Date(product.updatedAt).toLocaleDateString('en-GB')
                          : '—' %>
                  </dd>
                </div>
              </dl>
              <% if (!product.isDeleted) { %>
                <div class="pt-3 mt-3" style="border-top: 1px solid var(--border);">
                  <form method="POST" action="/products/<%= product.id %>/delete">
                    <button
                      type="submit"
                      class="btn btn-sm mb-3 btn-action danger"
                      data-name="<%= product.name %>"
                      onclick="return confirm('Delete ' + this.dataset.name + '? It can be restored later.')"
                    >
                      <i class="bi bi-trash me-1" aria-hidden="true"></i>Delete product
                    </button>
                    <p class="mb-0" style="font-size: 0.72rem; color: var(--text-3);">
                      Deleted products are hidden from customers but can be restored at any time.
                    </p>
                  </form>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../partials/scripts') %>
</body>
</html>
